{
  "title": "MicroShop SRE Dashboard",
  "uid": "microshop-sre",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Service Health (up = 1)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "up", "legendFormat": "{{job}}", "refId": "A" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": 0 },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Request Rate — Auth Service (req/min)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 8, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "rate(auth_requests_total[1m]) * 60", "legendFormat": "{{endpoint}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 3,
      "title": "Request Rate — Product Service (req/min)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 4, "w": 8, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "rate(product_requests_total[1m]) * 60", "legendFormat": "{{endpoint}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 4,
      "title": "Request Rate — Order Service (req/min)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 4, "w": 8, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "rate(order_requests_total[1m]) * 60", "legendFormat": "{{endpoint}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 5,
      "title": "Order Service — Error Rate (errors/min)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "rate(order_errors_total[1m]) * 60", "legendFormat": "{{type}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red",   "value": 0.01 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Total Errors (order_errors_total)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 12, "w": 6, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "sum(order_errors_total)", "legendFormat": "Total Errors", "refId": "A" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red",   "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Request Rate — User & Chat Services (req/min)",
      "type": "timeseries",
      "gridPos": { "x": 18, "y": 12, "w": 6, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "rate(user_requests_total[1m]) * 60",  "legendFormat": "user: {{endpoint}}",  "refId": "A" },
        { "expr": "rate(chat_requests_total[1m]) * 60",  "legendFormat": "chat: {{endpoint}}",  "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    }
  ]
}
